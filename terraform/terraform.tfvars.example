# Copy this file to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

# AWS region — change to your preferred region
aws_region = "us-east-1"

# Name of your existing EC2 key pair (must already exist in the region)
key_name = "my-key-pair"

# Your public IP in CIDR notation — restricts SSH to your machine only
# Find yours with: curl -s https://checkip.amazonaws.com && echo "/32"
your_ip = "YOUR_PUBLIC_IP/32"

# Instance type — t3.medium gives 2 vCPU + 4 GB RAM (workshop minimum)
instance_type = "t3.medium"

# Project tag applied to all resources
project_name = "votevibe"

# Optional: specify a VPC and subnet. Leave as "" to use the default VPC.
vpc_id    = ""
subnet_id = ""
